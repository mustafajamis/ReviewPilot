PORT=3000
APP_BASE_URL=http://localhost:3000

# Required for real GitHub webhook validation.
GITHUB_WEBHOOK_SECRET=replace-with-a-random-secret

# Required if you want ReviewPilot to post comments back to GitHub.
GITHUB_TOKEN=replace-with-github-token

# Optional. If omitted, ReviewPilot still runs rule-based checks.
OPENAI_API_KEY=replace-with-openai-api-key
OPENAI_MODEL=gpt-5.4
